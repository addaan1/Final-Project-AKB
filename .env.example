# =============================================================================
# Galbay Predictor - Environment Configuration
# =============================================================================
# Copy file ini ke .env dan isi kredensial Anda (JANGAN commit .env ke git).
# Semua field bersifat OPSIONAL. Tanpa kredensial, scraper akan jalan dengan
# data publik terbatas.
# =============================================================================

# ---------- TikTok (PRIORITAS 2) ----------
# Untuk akses data lebih banyak (tidak terblokir anti-bot headless browser).
# Cara dapat ms_token:
#   1. Login ke tiktok.com di browser
#   2. DevTools > Application > Cookies > tiktok.com > msToken
#   3. Copy value msToken ke variabel ini
#   4. Bisa juga beberapa msToken (pisahkan dengan koma) untuk rotasi
TIKTOK_MS_TOKENS=

# ---------- Reddit (PRIORITAS 3) ----------
# Untuk akses JSON API (tanpa login: rate-limited 10 req/menit).
# Cara dapat credentials:
#   1. Buka https://www.reddit.com/prefs/apps
#   2. Create app > type "script"
#   3. Copy client_id (di bawah nama app) & client_secret
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=GalbayPredictor/1.0 (academic research; contact: adieffendy5@gmail.com)

# ---------- Twitter/X (PRIORITAS 4) ----------
# Tanpa login: TIDAK BISA scrape (login wall).
# Untuk akses, perlu cookies dari browser yang sudah login ke X.
# Cara dapat cookies:
#   1. Login ke x.com di browser
#   2. DevTools > Application > Cookies > x.com
#   3. Copy value auth_token dan ct0 ke variabel ini
TWITTER_AUTH_TOKEN=
TWITTER_CT0=

# ---------- Scraping control ----------
# Sleep antar request (detik) untuk rate-limit sopan
SCRAPER_SLEEP_SECONDS=1.0
